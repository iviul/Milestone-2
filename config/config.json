{
  "project": {
    "name": "my-infra",
    "environment": "dev",
    "region": "europe",
    "os": "ubuntu"
  },

  "network": {
    "vpc_cidr": "10.0.0.0/16",
    "subnets": [
      {
        "name": "public-subnet",
        "cidr": "10.0.1.0/24",
        "public": true
      },
      {
        "name": "private-subnet",
        "cidr": "10.0.2.0/24",
        "public": false
      }
    ]
  },

  "vm_instances": [
    {
      "name": "frontend",
      "size": "small",
      "zone": "a",
      "subnet": "public-subnet",
      "tags": ["web", "frontend"],
      "port": 3000
    },
    {
      "name": "reverse-proxy",
      "size": "small",
      "zone": "a",
      "subnet": "public-subnet",
      "tags": ["proxy"],
      "port": 443
    },
    {
      "name": "backend",
      "size": "medium",
      "zone": "b",
      "subnet": "private-subnet",
      "tags": ["backend", "api"],
      "port": 8080
    },
    {
      "name": "redis",
      "size": "small",
      "zone": "b",
      "subnet": "private-subnet",
      "tags": ["cache"],
      "port": 6379
    }
  ],

  "databases": [
    {
      "name": "main-db",
      "type": "postgres",
      "version": "14",
      "size": "small",
      "zone": "b",
      "subnet": "private-subnet",
      "port": 5432
    }
  ],

  "networks": [
    { "name": "public",   "cidr": "0.0.0.0/0" },
    { "name": "internal", "cidr": "10.0.0.0/16" }
  ],

  "security_groups": [
    {
      "name": "sg-frontend",
      "attach_to": ["frontend"],
      "description": "Public access to frontend (port 3000)",
      "ingress": [
        { "protocol": "tcp", "port": 3000, "source": "public" }
      ],
      "egress": [
        { "protocol": "tcp", "port": 443, "destination": "reverse-proxy" }
      ]
    },
    {
      "name": "sg-reverse-proxy",
      "attach_to": ["reverse-proxy"],
      "description": "Accepts HTTPS from frontend, proxies to backend",
      "ingress": [
        { "protocol": "tcp", "port": 443, "source": "frontend" }
      ],
      "egress": [
        { "protocol": "tcp", "port": 8080, "destination": "backend" }
      ]
    },
    {
      "name": "sg-backend",
      "attach_to": ["backend"],
      "description": "Receives traffic from reverse proxy, accesses DB/Redis",
      "ingress": [
        { "protocol": "tcp", "port": 8080, "source": "reverse-proxy" }
      ],
      "egress": [
        { "protocol": "tcp", "port": 5432, "destination": "main-db" },
        { "protocol": "tcp", "port": 6379, "destination": "redis" }
      ]
    },
    {
      "name": "sg-db",
      "attach_to": ["main-db"],
      "description": "PostgreSQL — allow from backend",
      "ingress": [
        { "protocol": "tcp", "port": 5432, "source": "backend" }
      ],
      "egress": []
    },
    {
      "name": "sg-redis",
      "attach_to": ["redis"],
      "description": "Redis — allow from backend",
      "ingress": [
        { "protocol": "tcp", "port": 6379, "source": "backend" }
      ],
      "egress": []
    }
  ]
}
